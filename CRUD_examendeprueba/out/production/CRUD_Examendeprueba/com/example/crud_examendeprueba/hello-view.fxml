<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="15.0" xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.crud_examendeprueba.HelloController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
    </padding>

    <GridPane hgap="10" vgap="10">
        <Label text="Nombre:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
        <TextField fx:id="txtNombre" promptText="Ej. Juan Pérez" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
        <Button text="Buscar" onAction="#buscarContacto" GridPane.columnIndex="2" GridPane.rowIndex="0"/>

        <Label text="Teléfono:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
        <TextField fx:id="txtTelefono" promptText="10 dígitos" GridPane.columnIndex="1" GridPane.rowIndex="1"/>

        <Label text="Parentesco:" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
        <ComboBox fx:id="cmbParentesco" GridPane.columnIndex="1" GridPane.rowIndex="2"/>

        <HBox spacing="10" GridPane.columnIndex="0" GridPane.columnSpan="3" GridPane.rowIndex="3">
            <Button text="Agregar" onAction="#agregarContacto"/>
            <Button text="Actualizar" onAction="#actualizarContacto"/>
            <Button text="Eliminar" onAction="#eliminarContacto"/>
            <Button text="Limpiar" onAction="#limpiarCampos"/>
        </HBox>
    </GridPane>

    <Label text="Lista de Contactos:"/>
    <ListView fx:id="listViewContactos" VBox.vgrow="ALWAYS"/>
</VBox>