<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.GridPane?>

<GridPane fx:id="panelPrincipal" xmlns="http://javafx.com/javafx/19" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.crud_examendeprueba.HelloController" padding="15" hgap="10" vgap="10">
    <Label text="Nombre:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
    <TextField fx:id="txtNombre" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

    <Label text="Teléfono:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
    <TextField fx:id="txtTelefono" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

    <Label text="Parentesco:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
    <ComboBox fx:id="cmbParentesco" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

    <Button text="Agregar" onAction="#agregarContacto" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
    <Button text="Buscar" onAction="#buscarContacto" GridPane.rowIndex="3" GridPane.columnIndex="1"/>

    <Button text="Actualizar" onAction="#actualizarContacto" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
    <Button text="Eliminar" onAction="#eliminarContacto" GridPane.rowIndex="4" GridPane.columnIndex="1"/>

    <Button text="Limpiar" onAction="#limpiarCampos" GridPane.rowIndex="5" GridPane.columnIndex="0"/>

    <ListView fx:id="lvContactos" prefHeight="200" GridPane.rowIndex="6" GridPane.columnIndex="0" GridPane.columnSpan="2"/>
</GridPane>